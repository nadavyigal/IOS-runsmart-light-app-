// RunSmartSecrets.xcconfig.example — committed to git as a template
// Copy to RunSmartSecrets.xcconfig (gitignored) and fill in real values.
//
// On CI (Xcode Cloud / GitHub Actions / Fastlane):
//   echo "POSTHOG_API_KEY = $POSTHOG_API_KEY" > RunSmartSecrets.xcconfig
//
// RunSmartConfig.xcconfig is wired into the app target's Debug and Release
// build configurations and optionally includes this gitignored file.

POSTHOG_API_KEY = phc_REPLACE_WITH_REAL_KEY
